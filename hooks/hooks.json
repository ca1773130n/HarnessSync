{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "PY=$(command -v python3 || command -v python); [ -n \"$PY\" ] && \"$PY\" ${CLAUDE_PLUGIN_ROOT}/src/hooks/post_tool_use.py || true"
          }
        ]
      }
    ]
  }
}
